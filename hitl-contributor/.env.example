# =============================================
# HITL Open Source Contribution Agent - Config
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- LLM Provider ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-3.5-sonnet

# --- GitHub ---
# Fine-grained PAT: Public repos + Pull Requests only
GITHUB_TOKEN=github_pat_your-token-here
GITHUB_USERNAME=your-github-username

# --- Agent Behavior ---
# Comma-separated labels to search for on GitHub
ISSUE_LABELS=good first issue,help wanted
# Max number of issues to scan per run
MAX_ISSUES_TO_SCAN=5
# Programming languages to filter repositories by (comma-separated)
LANGUAGE_FILTER=python,javascript

# --- Docker Sandbox ---
DOCKER_IMAGE=python:3.11-slim
DOCKER_TIMEOUT_SECONDS=120

# --- Web Server ---
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_SECRET_KEY=change-me-to-a-random-string

# --- Scheduler (for 24/7 server deployments) ---
# Set AUTO_RUN=true to allow the scheduler to trigger runs automatically
AUTO_RUN=false
SCHEDULE_INTERVAL_HOURS=6

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
